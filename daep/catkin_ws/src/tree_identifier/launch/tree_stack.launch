<launch>
  <arg name="input_cloud_topic" default="/camera/depth/points" />
  <arg name="target_frame" default="world" />
  <arg name="run_plotter" default="true" />
  <arg name="run_fuser" default="true" />

  <!-- Tracker tuning -->
  <arg name="tracker_max_match_dist" default="1.5" />
  <arg name="tracker_max_missed_time" default="25.0" />
  <arg name="tracker_default_radius" default="0.30" />
  <arg name="tracker_default_height" default="2.0" />
  <arg name="tracker_marker_lifetime" default="0.8" />

  <!-- Fused map topics/params -->
  <arg name="map_pose_topic" default="/tree_map_poses" />
  <arg name="map_id_topic" default="/tree_map_ids" />
  <arg name="map_candidate_pose_topic" default="/tree_map_candidates" />
  <arg name="map_candidate_id_topic" default="/tree_map_candidate_ids" />
  <arg name="map_marker_topic" default="/tree_map_markers" />
  <arg name="fuser_association_dist" default="1.5" />
  <arg name="fuser_id_reuse_max_dist" default="2.2" />
  <arg name="fuser_min_confirmations" default="4" />
  <arg name="fuser_max_std_xy" default="-1.0" />
  <arg name="fuser_prune_unconfirmed_after_sec" default="60.0" />
  <arg name="fuser_publish_rate_hz" default="2.0" />
  <arg name="fuser_publish_candidates" default="true" />
  <arg name="fuser_log_throttle_sec" default="2.0" />
  <arg name="fuser_auto_export_period_sec" default="5.0" />
  <arg name="fuser_csv_output_path" default="/tmp/tree_map_final.csv" />
  <arg name="fuser_json_output_path" default="/tmp/tree_map_final.json" />

  <!-- Plotter -->
  <arg name="refresh_ms" default="500" />
  <arg name="show_xy_in_label" default="true" />
  <arg name="fixed_axes" default="true" />
  <arg name="x_min" default="-25.0" />
  <arg name="x_max" default="25.0" />
  <arg name="y_min" default="-28.0" />
  <arg name="y_max" default="20.0" />
  <arg name="tick_step" default="5.0" />
  <arg name="log_coords" default="true" />
  <arg name="log_throttle_sec" default="2.0" />
  <arg name="accumulate_unique" default="false" />
  <arg name="cache_by_id" default="true" />
  <arg name="dedup_dist" default="1.0" />
  <arg name="update_cached_position" default="false" />
  <arg name="log_only_on_new" default="false" />
  <arg name="show_live_labels" default="false" />
  <arg name="show_map_labels" default="true" />
  <arg name="show_metrics" default="true" />
  <arg name="max_labels" default="70" />

  <!-- Detector -->
  <include file="$(find tree_identifier)/launch/tree_detector.launch">
    <arg name="input_cloud_topic" value="$(arg input_cloud_topic)" />
    <arg name="target_frame" value="$(arg target_frame)" />
    <arg name="output_topic" value="/tree_detections" />
    <arg name="marker_topic" value="/tree_detections_raw_markers" />
  </include>

  <!-- Tracker/Identifier -->
  <include file="$(find tree_identifier)/launch/tree_id_tracker.launch">
    <arg name="input_topic" value="/tree_detections" />
    <arg name="output_topic" value="/tree_detections_tracked" />
    <arg name="id_topic" value="/tree_detection_ids" />
    <arg name="marker_topic" value="/tree_detection_markers" />
    <arg name="max_match_dist" value="$(arg tracker_max_match_dist)" />
    <arg name="max_missed_time" value="$(arg tracker_max_missed_time)" />
    <arg name="default_radius" value="$(arg tracker_default_radius)" />
    <arg name="default_height" value="$(arg tracker_default_height)" />
    <arg name="marker_lifetime" value="$(arg tracker_marker_lifetime)" />
  </include>

  <!-- Long-term tree map -->
  <include if="$(arg run_fuser)" file="$(find tree_identifier)/launch/tree_map_fuser.launch">
    <arg name="pose_topic" value="/tree_detections_tracked" />
    <arg name="id_topic" value="/tree_detection_ids" />
    <arg name="output_topic" value="$(arg map_pose_topic)" />
    <arg name="output_id_topic" value="$(arg map_id_topic)" />
    <arg name="candidate_topic" value="$(arg map_candidate_pose_topic)" />
    <arg name="candidate_id_topic" value="$(arg map_candidate_id_topic)" />
    <arg name="marker_topic" value="$(arg map_marker_topic)" />
    <arg name="association_dist" value="$(arg fuser_association_dist)" />
    <arg name="id_reuse_max_dist" value="$(arg fuser_id_reuse_max_dist)" />
    <arg name="min_confirmations" value="$(arg fuser_min_confirmations)" />
    <arg name="max_std_xy" value="$(arg fuser_max_std_xy)" />
    <arg name="prune_unconfirmed_after_sec" value="$(arg fuser_prune_unconfirmed_after_sec)" />
    <arg name="publish_rate_hz" value="$(arg fuser_publish_rate_hz)" />
    <arg name="publish_candidates" value="$(arg fuser_publish_candidates)" />
    <arg name="log_throttle_sec" value="$(arg fuser_log_throttle_sec)" />
    <arg name="auto_export_period_sec" value="$(arg fuser_auto_export_period_sec)" />
    <arg name="csv_output_path" value="$(arg fuser_csv_output_path)" />
    <arg name="json_output_path" value="$(arg fuser_json_output_path)" />
  </include>

  <!-- Live XY plot (optional) -->
  <include if="$(arg run_plotter)" file="$(find tree_identifier)/launch/tree_xy_plotter.launch">
    <arg name="pose_topic" value="/tree_detections_tracked" />
    <arg name="id_topic" value="/tree_detection_ids" />
    <arg name="refresh_ms" value="$(arg refresh_ms)" />
    <arg name="show_xy_in_label" value="$(arg show_xy_in_label)" />
    <arg name="fixed_axes" value="$(arg fixed_axes)" />
    <arg name="x_min" value="$(arg x_min)" />
    <arg name="x_max" value="$(arg x_max)" />
    <arg name="y_min" value="$(arg y_min)" />
    <arg name="y_max" value="$(arg y_max)" />
    <arg name="tick_step" value="$(arg tick_step)" />
    <arg name="log_coords" value="$(arg log_coords)" />
    <arg name="log_throttle_sec" value="$(arg log_throttle_sec)" />
    <arg name="accumulate_unique" value="$(arg accumulate_unique)" />
    <arg name="cache_by_id" value="$(arg cache_by_id)" />
    <arg name="dedup_dist" value="$(arg dedup_dist)" />
    <arg name="update_cached_position" value="$(arg update_cached_position)" />
    <arg name="log_only_on_new" value="$(arg log_only_on_new)" />
    <arg name="enable_map_overlay" value="$(arg run_fuser)" />
    <arg name="map_pose_topic" value="$(arg map_pose_topic)" />
    <arg name="map_id_topic" value="$(arg map_id_topic)" />
    <arg name="map_candidate_pose_topic" value="$(arg map_candidate_pose_topic)" />
    <arg name="map_candidate_id_topic" value="$(arg map_candidate_id_topic)" />
    <arg name="show_live_labels" value="$(arg show_live_labels)" />
    <arg name="show_map_labels" value="$(arg show_map_labels)" />
    <arg name="show_metrics" value="$(arg show_metrics)" />
    <arg name="max_labels" value="$(arg max_labels)" />
  </include>
</launch>
