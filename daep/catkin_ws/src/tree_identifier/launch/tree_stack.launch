<launch>
  <arg name="input_cloud_topic" default="/camera/depth/points" />
  <arg name="target_frame" default="world" />
  <arg name="run_plotter" default="true" />
  <arg name="run_cluster_plotter" default="false" />
  <arg name="run_fuser" default="true" />

  <!-- Tracker tuning -->
  <arg name="tracker_use_array_input" default="true" />
  <arg name="tracker_max_match_dist" default="0.6" />
  <arg name="tracker_max_diameter_delta" default="0.45" />
  <arg name="tracker_diameter_weight" default="0.4" />
  <arg name="tracker_position_alpha" default="0.45" />
  <arg name="tracker_diameter_alpha" default="0.38" />
  <arg name="tracker_min_detection_confidence" default="0.0" />
  <arg name="tracker_max_missed_time" default="25.0" />
  <arg name="tracker_default_radius" default="0.30" />
  <arg name="tracker_default_height" default="2.0" />
  <arg name="tracker_marker_lifetime" default="0.8" />

  <!-- Fused map topics/params -->
  <arg name="map_pose_topic" default="/tree_map_poses" />
  <arg name="map_id_topic" default="/tree_map_ids" />
  <arg name="map_array_topic" default="/tree_map_full" />
  <arg name="map_candidate_pose_topic" default="/tree_map_candidates" />
  <arg name="map_candidate_id_topic" default="/tree_map_candidate_ids" />
  <arg name="map_candidate_array_topic" default="/tree_map_candidate_full" />
  <arg name="map_marker_topic" default="/tree_map_markers" />
  <arg name="fuser_use_array_input" default="true" />
  <arg name="fuser_association_dist" default="0.70" />
  <arg name="fuser_id_reuse_max_dist" default="0.95" />
  <arg name="fuser_max_diameter_delta" default="0.45" />
  <arg name="fuser_diameter_assoc_weight" default="0.35" />
  <arg name="fuser_min_confirmations" default="4" />
  <arg name="fuser_max_std_xy" default="0.70" />
  <arg name="fuser_max_std_diameter" default="0.28" />
  <arg name="fuser_min_confirmed_confidence" default="0.0" />
  <arg name="fuser_prune_unconfirmed_after_sec" default="60.0" />
  <arg name="fuser_split_large_source_ids" default="18" />
  <arg name="fuser_split_std_xy_threshold" default="0.45" />
  <arg name="fuser_split_reject_dist" default="0.75" />
  <arg name="fuser_publish_rate_hz" default="2.0" />
  <arg name="fuser_publish_candidates" default="true" />
  <arg name="fuser_log_throttle_sec" default="2.0" />
  <arg name="fuser_auto_export_period_sec" default="5.0" />
  <arg name="fuser_csv_output_path" default="/tmp/tree_map_final.csv" />
  <arg name="fuser_json_output_path" default="/tmp/tree_map_final.json" />
  <arg name="detector_publish_debug_clusters" default="$(arg run_cluster_plotter)" />
  <arg name="cluster_points_topic" default="/tree_detector_cluster_points" />
  <arg name="cluster_labels_topic" default="/tree_detector_cluster_labels" />
  <arg name="detection_radius_topic" default="/tree_detection_radii" />
  <arg name="detector_output_array_topic" default="/tree_detections_full" />
  <arg name="detector_clustering_mode" default="dbscan_gmm" />
  <arg name="detector_dbscan_eps" default="0.30" />
  <arg name="detector_dbscan_min_samples" default="10" />
  <arg name="detector_enable_gmm_split" default="true" />
  <arg name="detector_gmm_radius_threshold" default="0.26" />
  <arg name="detector_gmm_min_points" default="24" />
  <arg name="detector_gmm_components" default="2" />
  <arg name="detector_gmm_min_center_dist" default="0.34" />
  <arg name="detector_ransac_min_inlier_ratio" default="0.18" />
  <arg name="experiment_seed" default="-1" />

  <!-- Plotter -->
  <arg name="refresh_ms" default="500" />
  <arg name="show_xy_in_label" default="true" />
  <arg name="fixed_axes" default="true" />
  <arg name="x_min" default="-10.0" />
  <arg name="x_max" default="10.0" />
  <arg name="y_min" default="-8.0" />
  <arg name="y_max" default="7.0" />
  <arg name="tick_step" default="5.0" />
  <arg name="log_coords" default="true" />
  <arg name="log_throttle_sec" default="2.0" />
  <arg name="accumulate_unique" default="false" />
  <arg name="cache_by_id" default="true" />
  <arg name="dedup_dist" default="1.0" />
  <arg name="update_cached_position" default="false" />
  <arg name="log_only_on_new" default="false" />
  <arg name="show_live_labels" default="false" />
  <arg name="show_map_labels" default="true" />
  <arg name="show_metrics" default="true" />
  <arg name="max_labels" default="70" />
  <arg name="cluster_plotter_snapshot_dir" default="/tmp/tree_cluster_snapshots" />
  <arg name="cluster_plotter_snapshot_prefix" default="tree_cluster_state" />
  <arg name="cluster_plotter_auto_snapshot_period_sec" default="0.0" />
  <arg name="cluster_plotter_save_png" default="true" />
  <arg name="cluster_plotter_show_tree_labels" default="true" />
  <arg name="cluster_plotter_show_map_labels" default="true" />
  <arg name="cluster_plotter_accumulate_history" default="true" />
  <arg name="cluster_plotter_plot_history" default="true" />
  <arg name="cluster_plotter_max_history_points" default="250000" />
  <arg name="cluster_plotter_history_label_stride" default="1000" />

  <!-- Detector -->
  <include file="$(find tree_identifier)/launch/tree_detector.launch">
    <arg name="input_cloud_topic" value="$(arg input_cloud_topic)" />
    <arg name="target_frame" value="$(arg target_frame)" />
    <arg name="output_topic" value="/tree_detections" />
    <arg name="output_array_topic" value="$(arg detector_output_array_topic)" />
    <arg name="marker_topic" value="/tree_detections_raw_markers" />
    <arg name="publish_debug_clusters" value="$(arg detector_publish_debug_clusters)" />
    <arg name="cluster_points_topic" value="$(arg cluster_points_topic)" />
    <arg name="cluster_labels_topic" value="$(arg cluster_labels_topic)" />
    <arg name="detection_radius_topic" value="$(arg detection_radius_topic)" />
    <arg name="clustering_mode" value="$(arg detector_clustering_mode)" />
    <arg name="dbscan_eps" value="$(arg detector_dbscan_eps)" />
    <arg name="dbscan_min_samples" value="$(arg detector_dbscan_min_samples)" />
    <arg name="enable_gmm_split" value="$(arg detector_enable_gmm_split)" />
    <arg name="gmm_radius_threshold" value="$(arg detector_gmm_radius_threshold)" />
    <arg name="gmm_min_points" value="$(arg detector_gmm_min_points)" />
    <arg name="gmm_components" value="$(arg detector_gmm_components)" />
    <arg name="gmm_min_center_dist" value="$(arg detector_gmm_min_center_dist)" />
    <arg name="ransac_min_inlier_ratio" value="$(arg detector_ransac_min_inlier_ratio)" />
    <arg name="experiment_seed" value="$(arg experiment_seed)" />
  </include>

  <!-- Tracker/Identifier -->
  <include file="$(find tree_identifier)/launch/tree_id_tracker.launch">
    <arg name="use_array_input" value="$(arg tracker_use_array_input)" />
    <arg name="input_topic" value="/tree_detections" />
    <arg name="input_array_topic" value="$(arg detector_output_array_topic)" />
    <arg name="output_topic" value="/tree_detections_tracked" />
    <arg name="output_array_topic" value="/tree_detections_tracked_full" />
    <arg name="id_topic" value="/tree_detection_ids" />
    <arg name="marker_topic" value="/tree_detection_markers" />
    <arg name="max_match_dist" value="$(arg tracker_max_match_dist)" />
    <arg name="max_diameter_delta" value="$(arg tracker_max_diameter_delta)" />
    <arg name="diameter_weight" value="$(arg tracker_diameter_weight)" />
    <arg name="position_alpha" value="$(arg tracker_position_alpha)" />
    <arg name="diameter_alpha" value="$(arg tracker_diameter_alpha)" />
    <arg name="min_detection_confidence" value="$(arg tracker_min_detection_confidence)" />
    <arg name="max_missed_time" value="$(arg tracker_max_missed_time)" />
    <arg name="default_radius" value="$(arg tracker_default_radius)" />
    <arg name="default_height" value="$(arg tracker_default_height)" />
    <arg name="marker_lifetime" value="$(arg tracker_marker_lifetime)" />
  </include>

  <!-- Long-term tree map -->
  <include if="$(arg run_fuser)" file="$(find tree_identifier)/launch/tree_map_fuser.launch">
    <arg name="use_array_input" value="$(arg fuser_use_array_input)" />
    <arg name="array_topic" value="/tree_detections_tracked_full" />
    <arg name="pose_topic" value="/tree_detections_tracked" />
    <arg name="id_topic" value="/tree_detection_ids" />
    <arg name="output_topic" value="$(arg map_pose_topic)" />
    <arg name="output_id_topic" value="$(arg map_id_topic)" />
    <arg name="output_array_topic" value="$(arg map_array_topic)" />
    <arg name="candidate_topic" value="$(arg map_candidate_pose_topic)" />
    <arg name="candidate_id_topic" value="$(arg map_candidate_id_topic)" />
    <arg name="candidate_array_topic" value="$(arg map_candidate_array_topic)" />
    <arg name="marker_topic" value="$(arg map_marker_topic)" />
    <arg name="association_dist" value="$(arg fuser_association_dist)" />
    <arg name="id_reuse_max_dist" value="$(arg fuser_id_reuse_max_dist)" />
    <arg name="max_diameter_delta" value="$(arg fuser_max_diameter_delta)" />
    <arg name="diameter_assoc_weight" value="$(arg fuser_diameter_assoc_weight)" />
    <arg name="min_confirmations" value="$(arg fuser_min_confirmations)" />
    <arg name="max_std_xy" value="$(arg fuser_max_std_xy)" />
    <arg name="max_std_diameter" value="$(arg fuser_max_std_diameter)" />
    <arg name="min_confirmed_confidence" value="$(arg fuser_min_confirmed_confidence)" />
    <arg name="prune_unconfirmed_after_sec" value="$(arg fuser_prune_unconfirmed_after_sec)" />
    <arg name="split_large_source_ids" value="$(arg fuser_split_large_source_ids)" />
    <arg name="split_std_xy_threshold" value="$(arg fuser_split_std_xy_threshold)" />
    <arg name="split_reject_dist" value="$(arg fuser_split_reject_dist)" />
    <arg name="publish_rate_hz" value="$(arg fuser_publish_rate_hz)" />
    <arg name="publish_candidates" value="$(arg fuser_publish_candidates)" />
    <arg name="log_throttle_sec" value="$(arg fuser_log_throttle_sec)" />
    <arg name="auto_export_period_sec" value="$(arg fuser_auto_export_period_sec)" />
    <arg name="csv_output_path" value="$(arg fuser_csv_output_path)" />
    <arg name="json_output_path" value="$(arg fuser_json_output_path)" />
  </include>

  <!-- Live XY plot (optional) -->
  <include if="$(arg run_plotter)" file="$(find tree_identifier)/launch/tree_xy_plotter.launch">
    <arg name="pose_topic" value="/tree_detections_tracked" />
    <arg name="id_topic" value="/tree_detection_ids" />
    <arg name="refresh_ms" value="$(arg refresh_ms)" />
    <arg name="show_xy_in_label" value="$(arg show_xy_in_label)" />
    <arg name="fixed_axes" value="$(arg fixed_axes)" />
    <arg name="x_min" value="$(arg x_min)" />
    <arg name="x_max" value="$(arg x_max)" />
    <arg name="y_min" value="$(arg y_min)" />
    <arg name="y_max" value="$(arg y_max)" />
    <arg name="tick_step" value="$(arg tick_step)" />
    <arg name="log_coords" value="$(arg log_coords)" />
    <arg name="log_throttle_sec" value="$(arg log_throttle_sec)" />
    <arg name="accumulate_unique" value="$(arg accumulate_unique)" />
    <arg name="cache_by_id" value="$(arg cache_by_id)" />
    <arg name="dedup_dist" value="$(arg dedup_dist)" />
    <arg name="update_cached_position" value="$(arg update_cached_position)" />
    <arg name="log_only_on_new" value="$(arg log_only_on_new)" />
    <arg name="enable_map_overlay" value="$(arg run_fuser)" />
    <arg name="map_pose_topic" value="$(arg map_pose_topic)" />
    <arg name="map_id_topic" value="$(arg map_id_topic)" />
    <arg name="map_candidate_pose_topic" value="$(arg map_candidate_pose_topic)" />
    <arg name="map_candidate_id_topic" value="$(arg map_candidate_id_topic)" />
    <arg name="show_live_labels" value="$(arg show_live_labels)" />
    <arg name="show_map_labels" value="$(arg show_map_labels)" />
    <arg name="show_metrics" value="$(arg show_metrics)" />
    <arg name="max_labels" value="$(arg max_labels)" />
  </include>

  <!-- Live Cluster Plot (optional, can run in parallel with tree_xy_plotter) -->
  <include if="$(arg run_cluster_plotter)" file="$(find tree_identifier)/launch/tree_cluster_xy_plotter.launch">
    <arg name="cluster_points_topic" value="$(arg cluster_points_topic)" />
    <arg name="cluster_labels_topic" value="$(arg cluster_labels_topic)" />
    <arg name="use_raw_array_input" value="true" />
    <arg name="raw_array_topic" value="$(arg detector_output_array_topic)" />
    <arg name="raw_pose_topic" value="/tree_detections" />
    <arg name="raw_radius_topic" value="$(arg detection_radius_topic)" />
    <arg name="refresh_ms" value="$(arg refresh_ms)" />
    <arg name="fixed_axes" value="$(arg fixed_axes)" />
    <arg name="x_min" value="$(arg x_min)" />
    <arg name="x_max" value="$(arg x_max)" />
    <arg name="y_min" value="$(arg y_min)" />
    <arg name="y_max" value="$(arg y_max)" />
    <arg name="tick_step" value="$(arg tick_step)" />
    <arg name="enable_map_overlay" value="$(arg run_fuser)" />
    <arg name="map_pose_topic" value="$(arg map_pose_topic)" />
    <arg name="map_id_topic" value="$(arg map_id_topic)" />
    <arg name="map_candidate_pose_topic" value="$(arg map_candidate_pose_topic)" />
    <arg name="map_candidate_id_topic" value="$(arg map_candidate_id_topic)" />
    <arg name="show_tree_labels" value="$(arg cluster_plotter_show_tree_labels)" />
    <arg name="show_map_labels" value="$(arg cluster_plotter_show_map_labels)" />
    <arg name="show_metrics" value="$(arg show_metrics)" />
    <arg name="log_throttle_sec" value="$(arg log_throttle_sec)" />
    <arg name="accumulate_history" value="$(arg cluster_plotter_accumulate_history)" />
    <arg name="plot_history" value="$(arg cluster_plotter_plot_history)" />
    <arg name="max_history_points" value="$(arg cluster_plotter_max_history_points)" />
    <arg name="history_label_stride" value="$(arg cluster_plotter_history_label_stride)" />
    <arg name="snapshot_dir" value="$(arg cluster_plotter_snapshot_dir)" />
    <arg name="snapshot_prefix" value="$(arg cluster_plotter_snapshot_prefix)" />
    <arg name="auto_snapshot_period_sec" value="$(arg cluster_plotter_auto_snapshot_period_sec)" />
    <arg name="save_png" value="$(arg cluster_plotter_save_png)" />
  </include>
</launch>
